# ============================================================
# AI 食物识别配置
# ============================================================

# 识别模式：gemini（Google Gemini，推荐，准确率高）| hunyuan（腾讯云混元）| zhipu（智谱GLM-4V，推荐）| baidu（百度菜品识别，中国食物最准）| mock（仅开发测试）
VITE_AI_MODE=openclaw

# ============================================================
# Google Gemini API 配置（推荐）
# ============================================================
# 1. 前往 https://aistudio.google.com/app/apikey 创建 API Key
# 2. 将下面的 YOUR_API_KEY 替换为你的实际 API Key
# 免费额度：Gemini 2.0 Flash 每天 1500 次请求
VITE_GEMINI_API_KEY=AIzaSyDX9ls89WtRmNs1MsmEE4gf4mRn5oBYQmI

# ============================================================
# 腾讯云混元 API 配置（备用）
# ============================================================
# 1. 前往 https://console.cloud.tencent.com/hunyuan/start 创建 API Key
# 2. 将下面的 YOUR_API_KEY 替换为你的实际 API Key
VITE_TENCENT_SECRET_KEY=sk-joBKekCPOLKLgbuAmEZ3lB6b661NxFHg4KkxDNk9OSyrEg1x

# ============================================================
# 智谱 GLM-4V API 配置（推荐）
# ============================================================
# 1. 前往 https://open.bigmodel.cn/ 注册并创建 API Key
# 2. 将下面的 YOUR_API_KEY 替换为你的实际 API Key
VITE_ZHIPU_API_KEY=a669cfa2a77f487e922b36a54b388034.lFFoPbUKRHMsrM9N

# ============================================================
# 百度菜品识别 API 配置（中国食物识别精度最高）
# ============================================================
# 1. 前往 https://console.bce.baidu.com/ai/#/ai/imagerecognition/overview/index
# 2. 创建「菜品识别」应用，获取 API Key 和 Secret Key
# 3. 免费额度：每天 500 次免费调用
# 注意：需要在 vite.config.ts 中加入 /api/baidu 代理（开发环境）
VITE_BAIDU_API_KEY=wnzX5AxIhW3KyJoGrUt1Kil1
VITE_BAIDU_SECRET_KEY=6h3IxlLI8z9bJfITHBFnLLjCLMJTvq4f

# ============================================================
# OpenClaw 代理模式配置（通过自己的服务器调用混元，最准）
# ============================================================
# 1. 服务器 IP：43.139.122.11（cloudflared 隧道，URL 可能变化）
# 2. 如隧道失效，需要重新在服务器上运行 cloudflared 获取新 URL
VITE_OPENCLAW_API_URL=https://authentic-tours-cancer-obtained.trycloudflare.com

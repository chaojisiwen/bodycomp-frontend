# ============================================================
# AI 食物识别配置
# ============================================================

# 识别模式：gemini（Google Gemini，推荐，准确率高）| hunyuan（腾讯云混元）| zhipu（智谱GLM-4V，推荐）| baidu（百度菜品识别，中国食物最准）| mock（仅开发测试）| openclaw（通过OpenClaw代理调用混元）
VITE_AI_MODE=gemini

# ============================================================
# Google Gemini API 配置（推荐）
# ============================================================
# 1. 前往 https://aistudio.google.com/app/apikey 创建 API Key
# 2. 将下面的 YOUR_API_KEY 替换为你的实际 API Key
# 免费额度：Gemini 2.0 Flash 每天 1500 次请求
VITE_GEMINI_API_KEY=YOUR_API_KEY

# ============================================================
# 腾讯云混元 API 配置（备用）
# ============================================================
# 1. 前往 https://console.cloud.tencent.com/hunyuan/start 创建 API Key
# 2. 将下面的 YOUR_API_KEY 替换为你的实际 API Key
VITE_TENCENT_SECRET_KEY=YOUR_SECRET_KEY

# ============================================================
# 智谱 GLM-4V API 配置（推荐）
# ============================================================
# 1. 前往 https://open.bigmodel.cn/ 注册并创建 API Key
# 2. 将下面的 YOUR_API_KEY 替换为你的实际 API Key
VITE_ZHIPU_API_KEY=YOUR_API_KEY

# ============================================================
# 百度菜品识别 API 配置（中国食物识别精度最高）
# ============================================================
# 1. 前往 https://console.bce.baidu.com/ai/#/ai/imagerecognition/overview/index
# 2. 创建「菜品识别」应用，获取 API Key 和 Secret Key
# 3. 免费额度：每天 500 次免费调用
VITE_BAIDU_API_KEY=YOUR_API_KEY
VITE_BAIDU_SECRET_KEY=YOUR_SECRET_KEY

# ============================================================
# OpenClaw 代理模式配置（通过自己的服务器调用混元，最准）
# ============================================================
# 1. 服务器 IP：43.139.122.11
# 2. cloudflared 隧道 URL（可能变化，需要在服务器上运行 cloudflared 获取）
VITE_OPENCLAW_API_URL=https://YOUR_TUNNEL_URL.trycloudflare.com
